# ─────────────────────────────────────────────
# RAG Pipeline Template – Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Supabase / PostgreSQL ──────────────────────
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Use the "Session" mode pooler URL for Railway (port 5432)
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT].supabase.co:5432/postgres

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Get this from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# ── App Settings ──────────────────────────────
APP_ENV=development            # development | production
LOG_LEVEL=INFO
ALLOWED_ORIGINS=*              # comma-separated list of allowed CORS origins

# ── RAG Settings ──────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct
RETRIEVAL_TOP_K=5
MAX_CONTEXT_TOKENS=4096

# ── Optional: API key for your own endpoint ───
# If set, all /api/* routes require: Authorization: Bearer <API_KEY>
API_KEY=
